{
    "manifest_version": 3,
    "name": "WriterDrip",
    "version": "1.0.2",
    "description": "Free open-source Google Docs typing extension with local-only pacing, flexible timelines, and pause or resume controls.",
    "permissions": [
        "activeTab",
        "alarms",
        "scripting",
        "storage"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "WriterDrip",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    }
}
